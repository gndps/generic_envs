#!/bin/bash

# Root directory for projenv
PROJECT_ENV_ROOT="$HOME/.projenv"
PROJECT_STATES_DIR="$PROJECT_ENV_ROOT/project_states"
FILE_STATES_DIR="$PROJECT_ENV_ROOT/file_states"
PROFILES_DIR="$PROJECT_ENV_ROOT/profiles"
PARENT_DIR=$(dirname "${BASH_SOURCE[0]}")
source $PARENT_DIR/fileops
source $PARENT_DIR/core
source $PARENT_DIR/profiles

# Initialize the necessary directories if they don't exist
mkdir -p "$PROJECT_STATES_DIR"
mkdir -p "$FILE_STATES_DIR"
mkdir -p "$PROFILES_DIR"

# Help function
projenv_help() {
    echo "Usage: projenv.sh [command] [arguments]"
    echo "Commands:"
    echo "  ----- Project Ops -----"
    echo "  * init project_alias           Initialize projenv with the current directory"
    echo "  * list|ls                      List all managed projects"
    echo "  * remove project_alias|index   Remove a project by alias or index"
    echo "  * activate project_alias|index Activate a project by alias or index, or special keyword 'git, poetry' to cd on current project's respective root folder."

    echo ""
    echo "  ----- File Ops -----"
    echo "  * cp file_path                 Add a file to the copy buffer"
    echo "  * paste                        Copy the file from the buffer to the current directory"
    echo "  * pasteall                     Paste all files from the buffer to the current directory"
    echo "  * list_files                   List all files in the buffer"

    echo ""
    echo "  ----- Profile Ops -----"
    echo "  * profile create profile_name   Create a new profile (save current state)"
    echo "  * profile load [name|index]     Load a profile by name or index"
    echo "  * profile update [name]         Update an existing profile (defaults to active)"
    echo "  * profile list                  List all profiles with indices"
    echo "  * load profile_name             Load a profile (legacy)"
    echo "  * save profile_name             Save a profile (legacy)"
    echo "  * update profile_name           Update a profile (legacy)"
}


# Autocompletion function for projenv activate
_projenv_activate_autocomplete() {
    local cur_word="${COMP_WORDS[COMP_CWORD]}"
    local projects=$(ls "$PROJECT_STATES_DIR" | sed 's/^[0-9]*_//')

    COMPREPLY=($(compgen -W "$projects" -- "$cur_word"))
}

# Register the autocompletion function for projenv activate
complete -F _projenv_activate_autocomplete projenv
complete -F _projenv_activate_autocomplete pa

# Main script logic
projenv() {
    case "$1" in
        init)
            if [[ -n "$2" ]]; then
                projenv_init "$2"
            else
                echo "Error: Project alias is required."
                projenv_help
            fi
            ;;
        list|ls)
            projenv_list
            ;;
        activate)
            if [[ -n "$2" ]]; then
                projenv_activate "$2"
            else
                echo "Error: Project alias or index is required."
                projenv_help
            fi
            ;;
        remove)
            if [[ -n "$2" ]]; then
                projenv_remove "$2"
            else
                echo "Error: Project alias or index is required."
                projenv_help
            fi
            ;;
        cp|copy)
            if [[ -n "$2" ]]; then
                projenv_copy_file "$2"
            else
                echo "Error: File path is required."
                projenv_help
            fi
            ;;
        paste)
            projenv_paste
            ;;
        pasteall)
            projenv_pasteall
            ;;
        list_files)
            projenv_list_files
            ;;
        profile)
            if [[ -n "$2" ]]; then
                case "$2" in
                    --help|-h)
                        echo "Profile Management Commands:"
                        echo "  create profile_name      Create a new profile (save current state)"
                        echo "  load [name|index]        Load a profile by name or index"
                        echo "  update [name]            Update an existing profile (defaults to active)"
                        echo "  list                     List all profiles with indices"
                        echo ""
                        echo "Examples:"
                        echo "  projenv profile create myprofile"
                        echo "  projenv profile load myprofile"
                        echo "  projenv profile load 1"
                        echo "  projenv profile update"
                        echo "  projenv profile update myprofile"
                        echo "  projenv profile list"
                        echo ""
                        echo "Aliases:"
                        echo "  pcreate name    -> projenv profile create name"
                        echo "  pload [name|index] -> projenv profile load [name|index]"
                        echo "  pupdate [name]  -> projenv profile update [name]"
                        echo "  plist           -> projenv profile list"
                        ;;
                    create)
                        if [[ -n "$3" ]]; then
                            projenv_profile_create "$3"
                        else
                            echo "Error: Profile name is required."
                            projenv_help
                        fi
                        ;;
                    load)
                        if [[ -n "$3" ]]; then
                            projenv_profile_load "$3"
                        else
                            echo "Error: Profile name or index is required."
                            projenv_help
                        fi
                        ;;
                    update)
                        projenv_profile_update "$3"
                        ;;
                    list)
                        projenv_profile_list
                        ;;
                    *)
                        echo "Error: Unknown profile command '$2'."
                        echo "Use 'projenv profile --help' for profile command help."
                        projenv_help
                        ;;
                esac
            else
                echo "Error: Profile command is required."
                echo "Use 'projenv profile --help' for profile command help."
                projenv_help
            fi
            ;;
        load)
            if [[ -n "$2" ]]; then
                projenv_profile_load "$2"
            else
                echo "Error: Profile name is required."
                projenv_help
            fi
            ;;
        save)
            if [[ -n "$2" ]]; then
                projenv_profile_create "$2"
            else
                echo "Error: Profile name is required."
                projenv_help
            fi
            ;;
        update)
            projenv_profile_update "$2"
            ;;
        *)
            projenv_help
            ;;
    esac
}

alias pa="projenv activate"
# alias km="projenv activate" # keyboard walk with space
function po {
    if [[ -z "$1" ]]; then
        echo "Please pass project"
        return
    fi
    projenv activate $@ && code .
}
function px {
    if [[ -z "$1" ]]; then
        echo "Please pass project"
        return
    fi
    projenv activate $@ && code -r .
}
alias pls="projenv list"
alias ikm="projenv list" # vertical downwards keyboard walk
alias pls="projenv list"
alias pin="projenv init"
alias pload="projenv profile load"
alias pcreate="projenv profile create"
alias pupdate="projenv profile update"
alias plist="projenv profile list"
alias ikmn="projenv init" # keyboard walk consistent with other projenv aliases
alias prm="projenv remove"
alias cp_="projenv cp"
alias copy="projenv cp"
alias cpls="projenv list_files"
alias pst="projenv paste"
alias pst_all="projenv pasteall"
alias paste="projenv pasteall"